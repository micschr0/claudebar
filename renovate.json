{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits"],
  "prCreation": "immediate",
  "rebaseWhen": "auto",
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "timezone": "Europe/Berlin",
  "schedule": ["after 8am and before 6pm on Monday"],
  "cargo": {
    "rangeStrategy": "update-lockfile"
  },
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"],
    "automerge": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["after 8am and before 6pm on Sunday"]
  },
  "packageRules": [
    {
      "description": "Never pin Cargo crate versions to exact '=' — Cargo.lock gives reproducibility",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["pin"],
      "enabled": false
    },
    {
      "description": "Group serde ecosystem",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["serde*"],
      "groupName": "serde ecosystem",
      "automerge": true
    },
    {
      "description": "Automerge non-major Cargo updates (CI is the gate); exclude pre-1.0 (semver) and require the dependency to already exist",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "description": "Group GitHub Actions bumps and automerge non-major",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions",
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
